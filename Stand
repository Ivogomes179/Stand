<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Veículos à Venda</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 font-sans">

  <div class="max-w-5xl mx-auto p-6">

    <!-- Header -->
    <header class="mb-8 text-center">
      <h1 class="text-3xl font-bold">🚗 Veículos à Venda</h1>
      <p class="text-gray-600 mt-2">Carros, motas e mais</p>
    </header>

    <!-- Menu -->
    <div class="flex justify-center gap-4 mb-10">
      <a href="#carros" class="bg-white px-4 py-2 rounded-xl shadow">Carros</a>
      <a href="#motas" class="bg-white px-4 py-2 rounded-xl shadow">Motas</a>
      <a href="#outros" class="bg-white px-4 py-2 rounded-xl shadow">Outros</a>
    </div>

    <!-- CARROS -->
    <section id="carros" class="mb-12">
      <h2 class="text-2xl font-bold mb-4">🚗 Carros</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-4 rounded-2xl shadow">
          <img src="images/bmw.jpg" class="rounded-xl mb-3">
          <h3 class="font-semibold">BMW Série 1</h3>
          <p class="text-gray-600">150.000 km • Diesel</p>
          <p class="font-bold mt-2">13.500€</p>
        </div>
      </div>
    </section>

    <!-- MOTAS -->
    <section id="motas" class="mb-12">
      <h2 class="text-2xl font-bold mb-4">🏍️ Motas</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-4 rounded-2xl shadow">
          <img src="images/mota.jpg" class="rounded-xl mb-3">
          <h3 class="font-semibold">Yamaha MT-07</h3>
          <p class="text-gray-600">30.000 km • 689cc</p>
          <p class="font-bold mt-2">6.500€</p>
        </div>
      </div>
    </section>

    <!-- OUTROS -->
    <section id="outros" class="mb-12">
      <h2 class="text-2xl font-bold mb-4">🚜 Outros</h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-4 rounded-2xl shadow">
          <img src="images/outro.jpg" class="rounded-xl mb-3">
          <h3 class="font-semibold">Carrinha de Trabalho</h3>
          <p class="text-gray-600">200.000 km</p>
          <p class="font-bold mt-2">4.000€</p>
        </div>
      </div>
    </section>

  </div>

</body>
</html>